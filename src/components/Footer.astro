---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="site-footer__inner">
    <nav class="site-footer__col" aria-label="Pages">
      <h2>Le site</h2>
      <ul>
        <li><a href="/blog">SEO/GEO</a></li>
        <li><a href="/brand-content">Brand content</a></li>
        <li><a href="/lexique">Lexique</a></li>
      </ul>
    </nav>
    <nav class="site-footer__col" aria-label="Présence">
      <h2>Me suivre</h2>
      <ul>
        <li>
          <a href="https://www.linkedin.com/in/jbrecolet/" rel="me noopener" target="_blank" class="site-footer__social-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
            LinkedIn
          </a>
        </li>
        <li>
          <a href="mailto:contact@jeanbaptisterecolet.fr" class="site-footer__social-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            Email
          </a>
        </li>
      </ul>
    </nav>
    <div class="site-footer__col">
      <h2>Mentions</h2>
      <ul>
        <li><a href="/mentions-legales">Mentions légales</a></li>
        <li><a href="/a-propos">À propos</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>
  </div>
  <div class="site-footer__copy-wrapper">
    <p class="site-footer__copy">
      © {year} Jean-Baptiste Récolet. Contenus citables avec attribution et lien
      vers la source.
    </p>
  </div>
</footer>
<style>
  .site-footer__inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    max-width: var(--max-w-page);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }
  .site-footer__col ul li {
    margin-top: 0.25rem;
  }
  .site-footer__social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .site-footer__copy-wrapper {
    max-width: var(--max-w-page);
    margin: var(--space-lg) auto 0;
    padding: 0 var(--space-md);
    text-align: center;
  }
  .site-footer__copy {
    color: var(--color-muted);
    font-size: 0.8125rem;
    max-width: none;
  }
  @media (max-width: 640px) {
    .site-footer__inner {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-md);
    }
    .site-footer h2 {
      font-size: 0.75rem;
    }
  }
</style>
