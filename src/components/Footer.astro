---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="site-footer__inner">
    <nav class="site-footer__col" aria-label="Pages">
      <h2>Le site</h2>
      <ul>
        <li><a href="/blog">Tous les articles</a></li>
        <li><a href="/lexique">Lexique</a></li>
      </ul>
    </nav>
    <nav class="site-footer__col" aria-label="Présence">
      <h2>Me suivre</h2>
      <ul>
        <li>
          <a href="https://www.linkedin.com/in/jbrecolet/" rel="me noopener" target="_blank">
            LinkedIn
          </a>
        </li>
        <li><a href="mailto:contact@jeanbaptisterecolet.fr">Email</a></li>
      </ul>
    </nav>
    <div class="site-footer__col">
      <h2>Mentions</h2>
      <ul>
        <li><a href="/mentions-legales">Mentions légales</a></li>
        <li><a href="/a-propos">À propos</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>
  </div>
  <div class="site-footer__copy-wrapper">
    <p class="site-footer__copy">
      © {year} Jean-Baptiste Récolet. Contenus citables avec attribution et lien
      vers la source.
    </p>
  </div>
</footer>

<style>
  .site-footer__inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    max-width: var(--max-w-page);
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .site-footer__col ul li {
    margin-top: 0.25rem;
  }

  .site-footer__copy-wrapper {
    max-width: var(--max-w-page);
    margin: var(--space-lg) auto 0;
    padding: 0 var(--space-md);
    text-align: center;
  }

  .site-footer__copy {
    color: var(--color-muted);
    font-size: 0.8125rem;
    max-width: none;
  }
</style>
