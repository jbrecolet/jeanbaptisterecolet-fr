---
const pathname = Astro.url.pathname;
const isActive = (p: string) =>
  p === '/' ? pathname === '/' : pathname.startsWith(p);
---
<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__brand" aria-label="Accueil">
      <span class="site-header__name">Jean-Baptiste Récolet</span>
      <span class="site-header__tag">Content Manager SEO & GEO</span>
    </a>
    <nav class="site-nav" aria-label="Navigation principale">
      <ul>
        <li>
          <a href="/blog" aria-current={isActive('/blog') ? 'page' : undefined}>
            Blog
          </a>
        </li>
        <li>
          <a href="/a-propos" aria-current={isActive('/a-propos') ? 'page' : undefined}>
            À propos
          </a>
        </li>
        <li>
          <a href="/contact" aria-current={isActive('/contact') ? 'page' : undefined}>
            Contact
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>
