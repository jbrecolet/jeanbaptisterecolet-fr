---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recent = sorted.slice(0, 6);
---

<BaseLayout
  title="Jean-Baptiste Récolet - Content Manager SEO & GEO"
  description="Portfolio et blog de Jean-Baptiste Récolet, Content Manager en région parisienne. Articles, méthodes et veille sur le SEO et le GEO."
>
  <section class="hero">
    <div class="hero__inner">

      <div class="hero__text">
        <h1>Jean-Baptiste Récolet<br />Content Manager SEO & GEO</h1>
        <p class="hero__subtitle hero__subtitle--accent">
          Des contenus lus par les humains, indexés par Google et cités par les IA.
        </p>
        <a href="/cv-jean-baptiste-recolet.pdf" class="hero__cv" download>
          Télécharger mon CV
        </a>
      </div>

      <div class="hero__visual">
        <img
          src="/hero.webp"
          alt="Jean-Baptiste Récolet, Content Manager SEO/GEO"
          width="600"
          height="600"
          loading="eager"
        />
      </div>

    </div>
  </section>

  <section class="section">
    <h2>Derniers articles</h2>
    {recent.length === 0 ? (
      <p class="empty-state">
        Le premier article arrive très bientôt. En attendant, vous pouvez me suivre
        sur <a href="https://www.linkedin.com/in/jbrecolet/">LinkedIn</a>.
      </p>
    ) : (
      <ul class="article-grid">
        {recent.map((post) => (
          <li class="article-card">
            {post.data.cover && (
              <a href={`/blog/${post.id}`} class="article-card__thumb" tabindex="-1" aria-hidden="true">
                <img
                  src={`/${post.data.cover}`}
                  alt={post.data.coverAlt ?? ''}
                />
              </a>
            )}
            <div class="article-card__body">
              <p class="article-card__category">{post.data.category?.toUpperCase()}</p>
              <h3 class="article-card__title">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h3>
              <p class="article-card__desc">{post.data.description}</p>
            </div>
          </li>
        ))}
      </ul>
    )}
    <p class="section__more">
      <a href="/blog">Voir tous les articles</a>
    </p>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .hero__subtitle {
    margin-top: var(--space-sm);
  }

  .hero__subtitle--accent {
    color: var(--color-accent);
  }

  .hero__cv {
    display: inline-block;
    margin-top: var(--space-md);
    padding: 0.6rem 1.25rem;
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
    border-radius: var(--radius);
  }
  .hero__cv:hover {
    opacity: 0.88;
    text-decoration: none;
  }

  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__visual img {
    width: 350px;
    height: 350px;
    display: block;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
  }

  @media (max-width: 720px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }
    .hero__visual {
      margin-top: var(--space-md);
    }
  }

  /* ── Sections ── */
  .section { margin-top: var(--space-lg); }
  .section h2 { margin-bottom: var(--space-md); }
  .section__more { margin-top: var(--space-lg); font-weight: 500; }

  .empty-state {
    color: var(--color-muted);
    font-style: italic;
    padding: var(--space-md) 0;
  }

  /* ── Grille articles ── */
  .article-grid {
    list-style: none;
    padding: 0;
    max-width: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .article-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    border-top: 1px solid var(--color-rule);
    padding-top: var(--space-md);
  }

  .article-card__thumb {
    display: block;
    width: 100%;
  }
  .article-card__thumb img {
    width: 100%;
    height: 220px;
    display: block;
    border-radius: var(--radius);
  }
  .article-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }
  .article-card__category { font-size: 0.8rem; color: var(--color-accent); font-weight: bold; }
  .article-card__title { margin: 0; }
  .article-card__title a { text-decoration: none; color: inherit; }
  .article-card__title a:hover { color: var(--color-accent); }
  .article-card__desc { color: var(--color-muted); font-size: 0.9375rem; }

  @media (max-width: 900px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .article-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
