---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recent = sorted.slice(0, 6);

const getExcerpt = (entry) => {
  if (entry.data.excerpt) return entry.data.excerpt;
  const paragraphs = (entry.body ?? '').split('\n\n').filter(p => {
    const t = p.trim();
    return (
      t &&
      !t.startsWith('#') &&
      !t.startsWith('---') &&
      !t.startsWith('<') &&
      !t.startsWith('|') &&
      !t.startsWith('-') &&
      !t.startsWith('*')
    );
  });
  const first = paragraphs[0]
    ?.replace(/\*\*/g, '')
    .replace(/\*/g, '')
    .replace(/_/g, '')
    .trim();
  return first || entry.data.description;
};
---

<BaseLayout
  title="Jean-Baptiste Récolet - Content Manager Brand content, SEO & GEO"
  description="Portfolio et blog de Jean-Baptiste Récolet, Content Manager en région parisienne. Brand content, méthodes SEO et veille GEO."
>
  <section class="hero">
    <div class="hero__inner">
      <div class="hero__text">
        <h1>
          <span class="hero__name">Jean-Baptiste Récolet</span>
          <span class="hero__role">Content Manager</span>
          <span class="hero__role hero__role--accent"><em>Brand content, SEO & GEO</em></span>
        </h1>
        <a href="/cv-jean-baptiste-recolet.pdf" class="hero__cv" download>
          Télécharger mon CV
        </a>
      </div>
      <div class="hero__visual">
        <img
          src="/hero.webp"
          alt="Jean-Baptiste Récolet, Content Manager Brand content, SEO & GEO"
          width="600"
          height="600"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <div class="manifeste">
    <p>À la fois blog éditorial et laboratoire de méthodes SEO/GEO, ce site est le portfolio de certains de mes travaux passés en matière de <em>brand content</em> et de mes études actuelles sur le <em>search</em>.</p>
    <p>Il est également et avant tout le reflet de ma conception du métier de Content Manager : concevoir et écrire des contenus lus par les humains, indexés par Google et cités par les IA.</p>
  </div>

  <section class="section">
    <h2>Derniers articles</h2>
    {recent.length === 0 ? (
      <p class="empty-state">
        Le premier article arrive très bientôt. En attendant, vous pouvez me suivre
        sur <a href="https://www.linkedin.com/in/jbrecolet/">LinkedIn</a>.
      </p>
    ) : (
      <ul class="article-grid">
        {recent.map((post) => (
          <li class="article-card">
            {post.data.cover && (
              <a href={`/blog/${post.id}`} class="article-card__thumb" tabindex="-1" aria-hidden="true">
                <img
                  src={`/${post.data.cover}`}
                  alt={post.data.coverAlt ?? ''}
                />
              </a>
            )}
            <div class="article-card__body">
              <p class="article-card__category">{post.data.category?.toUpperCase()}</p>
              <h3 class="article-card__title">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h3>
              <p class="article-card__desc">{getExcerpt(post)}</p>
            </div>
          </li>
        ))}
      </ul>
    )}
    <p class="section__more">
      <a href="/blog">Voir tous les articles</a>
    </p>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .hero__name {
    font-weight: 400;
    font-size: clamp(1.5rem, 3vw, 2rem);
    display: block;
  }

  .hero__role {
    font-weight: 800;
    font-size: clamp(2rem, 4vw, 2.75rem);
    display: block;
    line-height: 1.15;
  }

  .hero__role--accent {
  white-space: nowrap;
}

.hero__role--accent em {
  font-style: italic;
  font-weight: 600;
  color: var(--color-accent);
}

    .hero__cv {
    display: inline-block;
    margin-top: var(--space-sm);
    padding: 0.6rem 1.25rem;
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
    border-radius: var(--radius);
  }
  .hero__cv:hover { opacity: 0.88; text-decoration: none; }

  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero__visual img {
    width: 280px;
    height: 280px;
    display: block;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
  }

  @media (max-width: 720px) {
    .hero__inner { grid-template-columns: 1fr; }
    .hero__visual { margin-top: var(--space-md); }
  }

  /* ── Manifeste ── */
  .manifeste {
  border-top: 1px solid var(--color-rule);
  border-bottom: 1px solid var(--color-rule);
  padding: var(--space-md) 0;
  margin: 0.75rem 0;
  }

  .manifeste p {
    font-size: 1.15rem;
    line-height: 1.8;
    max-width: none;
  }

  .manifeste p + p {
    margin-top: var(--space-sm);
  }

  /* ── Sections ── */
  .section { margin-top: var(--space-lg); }
  .section h2 { margin-bottom: var(--space-md); }
  .section__more { margin-top: var(--space-lg); font-weight: 500; }

  .empty-state {
    color: var(--color-muted);
    font-style: italic;
    padding: var(--space-md) 0;
  }

  /* ── Grille articles ── */
  .article-grid {
    list-style: none;
    padding: 0;
    max-width: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .article-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding-top: var(--space-md);
  }

  .article-card__thumb { display: block; width: 100%; }
  .article-card__thumb img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    border-radius: var(--radius);
  }

  .article-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .article-card__category {
    font-size: 0.8rem;
    color: var(--color-accent);
    font-weight: bold;
  }

  .article-card__title {
    margin: 0;
    min-height: 3.6em;
  }

  .article-card__title a {
    text-decoration: none;
    color: inherit;
  }

  .article-card__title a:hover { color: var(--color-accent); }

  .article-card__desc {
    color: var(--color-muted);
    font-size: 0.9375rem;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: auto;
  }

  @media (max-width: 900px) {
    .article-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .article-grid { grid-template-columns: 1fr; }
  }
</style>
