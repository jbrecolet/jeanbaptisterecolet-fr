---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = sorted.filter((p) => p.data.featured).slice(0, 1);
const recent = sorted.filter((p) => !p.data.featured).slice(0, 6);

const dateFmt = new Intl.DateTimeFormat('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title="Content manager SEO/GEO - Jean-Baptiste Récolet"
  description="Méthodes, retours d'expérience et veille pour Content Managers en 2026. Comprendre, mettre en œuvre et mesurer le GEO en français."
>
  <section class="hero">
    <div class="hero__inner">

      <div class="hero__text">
        <h1>Du SEO au GEO : la nouvelle stratégie de contenu pour le Search</h1>
        <p class="hero__subtitle hero__subtitle--accent">
          Des contenus lus par les humains, indexés par Google et cités par les IA.
        </p>
      </div>

      <div class="hero__visual">
        <img
          src="/hero.webp"
          alt="Jean-Baptiste Récolet, Content Manager SEO/GEO"
          width="600"
          height="600"
          loading="eager"
        />
      </div>

    </div>
  </section>

  {featured.length > 0 && (
    <section class="section">
      <h2>À la une</h2>
      <ul class="article-list">
        {featured.map((post) => (
          <li class="article-card">
            {post.data.cover && (
              <div class="article-card__thumb">
                <a href={`/blog/${post.id}`} tabindex="-1" aria-hidden="true">
                  <Image
                    src={post.data.cover}
                    alt={post.data.coverAlt ?? ''}
                    width={200}
                    height={130}
                  />
                </a>
              </div>
            )}
            <div class="article-card__body">
              <p class="article-card__category">{post.data.category.toUpperCase()}</p>
              <h3 class="article-card__title">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h3>
              <p class="article-card__desc">{post.data.description}</p>
              <p class="article-card__meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {dateFmt.format(post.data.pubDate)}
                </time>
              </p>
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="section">
    <h2>Derniers articles</h2>
    {recent.length === 0 ? (
      <p class="empty-state">
        Le premier article arrive très bientôt. En attendant, vous pouvez me suivre
        sur <a href="https://www.linkedin.com/in/jbrecolet/">LinkedIn</a>.
      </p>
    ) : (
      <ul class="article-list">
        {recent.map((post) => (
          <li class="article-card">
            {post.data.cover && (
              <div class="article-card__thumb">
                <a href={`/blog/${post.id}`} tabindex="-1" aria-hidden="true">
                  <Image
                    src={post.data.cover}
                    alt={post.data.coverAlt ?? ''}
                    width={200}
                    height={130}
                  />
                </a>
              </div>
            )}
            <div class="article-card__body">
              <p class="article-card__category">{post.data.category.toUpperCase()}</p>
              <h3 class="article-card__title">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h3>
              <p class="article-card__desc">{post.data.description}</p>
              <p class="article-card__meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {dateFmt.format(post.data.pubDate)}
                </time>
              </p>
            </div>
          </li>
        ))}
      </ul>
    )}
    <p class="section__more">
      <a href="/blog">Voir tous les articles</a>
    </p>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .hero__subtitle {
    margin-top: var(--space-sm);
  }

  .hero__subtitle--accent {
    color: var(--color-accent);
  }

  .hero__cta {
    margin-top: var(--space-lg);
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__visual img {
    width: 350px;
    height: 350px;
    display: block;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
  }

  @media (max-width: 720px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }
    .hero__visual {
      margin-top: var(--space-md);
    }
  }

  /* ── Boutons ── */


  /* ── Sections ── */
  .section { margin-top: var(--space-xl); }
  .section--narrow { max-width: var(--max-w-text); }
  .section h2 { margin-bottom: var(--space-md); }
  .section__more { margin-top: var(--space-md); font-weight: 500; }

  .article-list { list-style: none; padding: 0; }
  .empty-state {
    color: var(--color-muted);
    font-style: italic;
    padding: var(--space-md) 0;
  }

  /* ── Cartes articles ── */
  .article-card {
    display: flex;
    flex-direction: row;
    gap: var(--space-md);
    align-items: flex-start;
    border-top: 1px solid var(--color-rule);
    padding: var(--space-md) 0;
  }
  .article-card:last-child { border-bottom: 1px solid var(--color-rule); }

  .article-card__thumb { flex-shrink: 0; width: 160px; }
  .article-card__thumb img {
    width: 100%;
    height: 100px;
    object-fit: cover;
    border-radius: var(--radius);
    display: block;
  }
  .article-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .article-card__category { font-size: 0.8rem; color: var(--color-accent); font-weight: bold; }
  .article-card__title { margin: 0; }
  .article-card__title a { text-decoration: none; color: inherit; }
  .article-card__title a:hover { color: var(--color-accent); }
  .article-card__desc { color: var(--color-muted); }
  .article-card__meta { font-size: 0.9rem; color: var(--color-muted); }
</style>
