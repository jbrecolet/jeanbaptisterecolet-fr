---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = sorted.filter((p) => p.data.featured).slice(0, 3);
const recent = sorted.slice(0, 6);

const dateFmt = new Intl.DateTimeFormat('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title="GEO et SEO en francais - Jean-Baptiste Recolet"
  description="Methodes, retours d'experience et veille pour Content Managers en 2026. Comprendre, mettre en oeuvre et mesurer le GEO en francais."
>
<section class="section hero">
    <div class="hero__container">
      <div class="hero__content">
        <p class="section__intro">CONTENT MANAGER - SEO - GEO</p>
        <h1 class="hero__title">Le GEO en français : méthodes, transition SEO et veille pour Content Managers</h1>
        <p class="hero__desc">
          Je documente la transition entre SEO classique et Generative Engine Optimization sur le marché francophone. Méthodes opérationnelles, retours d'expérience et analyse des annonces qui comptent.
        </p>
        <div class="hero__actions">
          <a href="/le-guide-du-geo-en-2026" class="button button--primary">Lire le guide GEO 2026</a>
          <a href="/blog" class="button button--secondary">Tous les articles</a>
        </div>
      </div>
      
      <div class="hero__visual">
        <img 
          src="/images/visuel-geo-france.webp" 
          alt="Illustration de la transition du SEO vers le GEO en France" 
          width="500" 
          height="500"
          class="hero__image"
        />
      </div>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="section">
      <h2>A la une</h2>
      <ul class="article-list">
        {featured.map((post) => (
          <li class="article-card">
            <p class="article-card__category">{post.data.category.toUpperCase()}</p>
            <h3 class="article-card__title">
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h3>
            <p class="article-card__desc">{post.data.description}</p>
            <p class="article-card__meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {dateFmt.format(post.data.pubDate)}
              </time>
            </p>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="section">
    <h2>Derniers articles</h2>
    {recent.length === 0 ? (
      <p class="empty-state">
        Le premier article arrive tres bientot. En attendant, tu peux me suivre
        sur <a href="https://www.linkedin.com/in/jbrecolet/">LinkedIn</a>.
      </p>
    ) : (
      <ul class="article-list">
        {recent.map((post) => (
          <li class="article-card">
            <p class="article-card__category">{post.data.category.toUpperCase()}</p>
            <h3 class="article-card__title">
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h3>
            <p class="article-card__desc">{post.data.description}</p>
            <p class="article-card__meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {dateFmt.format(post.data.pubDate)}
              </time>
            </p>
          </li>
        ))}
      </ul>
    )}
    <p class="section__more">
      <a href="/blog">Voir tous les articles</a>
    </p>
  </section>

  <section class="section section--narrow">
    <h2>A propos</h2>
    <p>
      Je m'appelle Jean-Baptiste Recolet, je suis Content Manager specialise en
      redaction, gestion editoriale, SEO et GEO. Base en region parisienne, je
      construis ce site comme un terrain d'application des methodes que je
      partage : chaque page est elle-meme optimisee pour etre citee par les
      moteurs IA.
    </p>
    <p>
      <a href="/a-propos">En savoir plus</a>
    </p>
  </section>
</BaseLayout>

<style>
  .hero__kicker {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8125rem;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }
  .hero__cta {
    margin-top: var(--space-lg);
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--color-text);
    color: var(--color-bg);
    text-decoration: none;
    border-radius: var(--radius);
    font-weight: 500;
    transition: background 0.15s;
  }
  .btn:hover { background: var(--color-accent); }
  .btn--ghost {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-rule);
  }
  .btn--ghost:hover { background: var(--color-text); color: var(--color-bg); }

  .section { margin-top: var(--space-xl); }
  .section--narrow { max-width: var(--max-w-text); }
  .section h2 { margin-bottom: var(--space-md); }
  .section__more { margin-top: var(--space-md); font-weight: 500; }

  .article-list { list-style: none; padding: 0; }
  .empty-state {
    color: var(--color-muted);
    font-style: italic;
    padding: var(--space-md) 0;
  }
</style>
