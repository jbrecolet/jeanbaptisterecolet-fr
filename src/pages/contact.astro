---
import BaseLayout from '~/layouts/BaseLayout.astro';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  mainEntity: {
    '@type': 'Person',
    name: 'Jean-Baptiste Récolet',
    email: 'mailto:contact@jeanbaptisterecolet.fr',
    url: 'https://jeanbaptisterecolet.fr',
    sameAs: ['https://www.linkedin.com/in/jbrecolet/'],
  },
};
---

<BaseLayout
  title="Contact — Jean-Baptiste Recolet"
  description="Pour toute question, opportunité professionnelle ou proposition de collaboration autour du SEO et du GEO, contact direct par email ou via LinkedIn."
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(contactSchema)}
  />

  <article class="prose">
    <header>
      <h1>Contact</h1>
      <p class="lead">
        Pour une opportunité professionnelle ou une question sur un
        article, vous pouvez me contacter par email ou via LinkedIn.
      </p>
    </header>

    <h2>Email</h2>
    <p>
      <a href="mailto:contact@jeanbaptisterecolet.fr">contact@jeanbaptisterecolet.fr</a>
    </p>

    <h2>LinkedIn</h2>
    <p>
      <a href="https://www.linkedin.com/in/jbrecolet/" rel="me noopener" target="_blank">
        linkedin.com/in/jbrecolet
      </a>
    </p>
  </article>
</BaseLayout>

<style>
  .prose { max-width: var(--max-w-text); margin: var(--space-lg) auto; }
  .prose .lead { font-size: 1.125rem; color: var(--color-muted); margin-bottom: var(--space-lg); }
  .prose h2 { margin-top: var(--space-lg); }
  .prose p { margin-top: var(--space-sm); }
</style>
