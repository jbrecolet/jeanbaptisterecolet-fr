---
import BaseLayout from '~/layouts/BaseLayout.astro';

const terms = [
  // A
  {
    letter: 'A',
    id: 'aeo',
    name: 'AEO (Answer Engine Optimization)',
    definition: "Discipline d'optimisation visant à faire apparaître du contenu dans les réponses directes des moteurs de recherche et des IA. L'AEO cible les Featured Snippets, les réponses vocales et les AI Overviews. Souvent utilisé comme synonyme de GEO, bien que certains praticiens distinguent l'AEO (optimisation pour les extraits de réponse) du GEO (qui englobe l'ensemble de la visibilité dans les LLMs).",
  },
  {
    letter: 'A',
    id: 'ai-mode',
    name: 'AI Mode (Google)',
    definition: "Interface conversationnelle et immersive de Google Search, distincte des AI Overviews. L'AI Mode s'active lorsque l'utilisateur bascule volontairement dans un flux de discussion continu avec Gemini. Contrairement aux AI Overviews qui synthétisent la SERP classique, l'AI Mode affiche une volatilité des sources beaucoup plus forte, avec un taux de rotation (citation drift) mesuré à 56 % par semaine par Sistrix en mai 2026.",
  },
  {
    letter: 'A',
    id: 'ai-overviews',
    name: 'AI Overviews',
    definition: "Fonctionnalité de Google déployée à partir de 2024 qui génère une réponse synthétisée en haut des résultats de recherche, avant les liens organiques. Alimentée par Gemini, elle compile des informations issues de plusieurs sources et cite ces sources sous la réponse. Sa présence dans 25 % des requêtes en 2026 a provoqué une baisse mesurable du taux de clic organique. À ne pas confondre avec Google AI Mode, une interface conversationnelle distincte.",
  },
  {
    letter: 'A',
    id: 'algorithme',
    name: 'Algorithme (Google)',
    definition: "Ensemble de règles et de signaux utilisés par Google pour classer les pages web dans ses résultats de recherche. L'algorithme intègre plusieurs centaines de facteurs : pertinence du contenu, autorité des backlinks, expérience utilisateur (Core Web Vitals), fraîcheur, E-E-A-T... Il est mis à jour régulièrement via des core updates et des mises à jour ciblées (Panda, Penguin, Helpful Content). Comprendre ses évolutions est au cœur du travail SEO.",
  },
  {
    letter: 'A',
    id: 'anchor-text',
    name: 'Anchor text',
    definition: 'Texte cliquable d\'un lien hypertexte, visible par l\'utilisateur et interprété par les moteurs de recherche comme un signal de contexte sur la page de destination. Un anchor text descriptif (ex. : "guide GEO complet") transmet plus d\'information sémantique qu\'un anchor générique (ex. : "cliquez ici"). En SEO, la diversité et la naturalité des anchor texts d\'un profil de backlinks sont des signaux de qualité.',
  },
  {
    letter: 'A',
    id: 'answer-capsule',
    name: 'Answer Capsule',
    definition: "Format de contenu structuré optimisé pour la récupération par les LLMs. Une Answer Capsule combine un titre formulé comme une question, un résumé de 2 à 3 lignes en ouverture, une réponse structurée avec sous-titres et listes, des données sourcées et datées, et une conclusion ouverte. Ce format se fait citer 3 à 5 fois plus souvent dans les réponses IA que les contenus non structurés, selon les analyses de citations LLM.",
  },
  {
    letter: 'A',
    id: 'answer-share',
    name: 'Answer Share',
    definition: "Indicateur de performance clé (KPI) en GEO représentant la part en pourcentage de requêtes (ou de prompts) pour lesquelles un domaine est explicitement cité en source par un moteur génératif, sur un échantillon de recherche donné. Proche de la Part de voix IA, l'Answer Share permet de mesurer la pénétration algorithmique d'une marque au sein des réponses textuelles des LLM, indépendamment du volume de clics généré.",
  },
  {
    letter: 'A',
    id: 'autorite-de-domaine',
    name: 'Autorité de domaine',
    definition: "Score propriétaire développé par Moz (de 1 à 100) estimant la capacité d'un site à se classer dans les résultats de recherche. Il est calculé à partir du nombre et de la qualité des backlinks pointant vers le site. Ce n'est pas une métrique officielle de Google, mais elle est largement utilisée dans le secteur SEO comme indicateur comparatif entre domaines concurrents.",
  },
  // B
  {
    letter: 'B',
    id: 'backlink',
    name: 'Backlink',
    definition: "Lien hypertexte placé sur un site externe qui pointe vers une page de son propre site. Les backlinks constituent l'un des principaux signaux d'autorité pris en compte par les algorithmes de Google. En GEO en revanche, leur corrélation avec la visibilité dans les LLMs est faible (0,12 selon LLM Research Lab, 2026), bien inférieure à celle des citations éditoriales (0,61).",
  },
  {
    letter: 'B',
    id: 'balisage-schemaorg',
    name: 'Balisage schema.org',
    definition: "Ensemble de balises de données structurées standardisées permettant d'indiquer aux moteurs de recherche et aux LLMs la nature précise du contenu d'une page (article, FAQ, produit, recette, événement...). Implémenté en JSON-LD dans le head des pages, le schema.org améliore l'extractibilité du contenu par les IA. Le LLM Research Lab (2026) mesure +28 % de citations globales pour les pages balisées, montant à +32 % pour les types Review et AggregateRating.",
  },
  {
    letter: 'B',
    id: 'brand-search-lift',
    name: 'Brand Search Lift',
    definition: "Augmentation mesurable du volume de recherches directes associées au nom d'une marque sur les moteurs traditionnels (Google, Bing), consécutive à l'apparition répétée de cette marque dans les réponses des LLM. Ce phénomène compense la baisse du CTR organique : l'utilisateur mémorise la marque citée par ChatGPT ou Perplexity comme une autorité de référence, puis va directement la chercher sur le web pour finaliser son parcours.",
  },
  {
    letter: 'B',
    id: 'brand-search-volume',
    name: 'Brand Search Volume',
    definition: "Nombre total de fois où le nom exact d'une marque (ou ses variantes directes) est recherché par les utilisateurs sur une période donnée. En stratégie GEO, le suivi du Brand Search Volume est un indicateur indirect majeur : il permet de quantifier la mémorisation et la confiance induites par la visibilité off-site au sein des agents conversationnels.",
  },
  // C
  {
    letter: 'C',
    id: 'canonical',
    name: 'Canonical',
    definition: "Balise HTML indiquant aux moteurs de recherche quelle est la version de référence d'une page lorsque plusieurs URLs affichent un contenu identique ou similaire. La balise canonical évite les problèmes de duplication de contenu qui peuvent diluer l'autorité SEO d'une page. Elle est particulièrement utilisée sur les sites e-commerce où un même produit peut être accessible via plusieurs URLs.",
  },
  {
    letter: 'C',
    id: 'cannibalisation',
    name: 'Cannibalisation',
    definition: "Phénomène SEO dans lequel plusieurs pages d'un même site ciblent les mêmes mots-clés et se font concurrence dans les résultats de recherche. La cannibalisation dilue l'autorité SEO entre les pages concernées et envoie un signal de confusion à Google sur laquelle prioriser. Elle se corrige en fusionnant les pages concurrentes, en précisant les cibles sémantiques de chacune, ou en ajoutant des balises canonical.",
  },
  {
    letter: 'C',
    id: 'chunk',
    name: 'Chunk',
    definition: "Fragment de texte de 60 à 500 mots extrait d'une page web par un LLM lors de la phase de récupération (RAG). Les LLMs ne lisent pas les pages entières : ils découpent le contenu en chunks, les convertissent en représentations vectorielles (embeddings) et sélectionnent les plus pertinents pour assembler une réponse. Un paragraphe autoporteur qui répond directement à une question forme un bon chunk extractible.",
  },
  {
    letter: 'C',
    id: 'citation-bias',
    name: 'Citation Bias',
    definition: "Tendance d'un grand modèle de langage (LLM) à privilégier et citer systématiquement certaines sources ou typologies de plateformes au détriment d'autres, en raison de biais présents dans son corpus d'entraînement ou dans les règles de son algorithme de RAG. Le plus documenté est le biais de notoriété (ou d'autorité), qui pousse les IA à sur-citer les domaines à très fort trafic historique ou les plateformes ayant signé des accords d'indexation spécifiques (ex. : Reddit, LinkedIn).",
  },
  {
    letter: 'C',
    id: 'citation-drift',
    name: 'Citation Drift',
    definition: "Tendance des moteurs de réponses IA à modifier ou remplacer constamment les sources web qu'ils citent pour une seule et même requête au fil du temps. Mesuré en mai 2026 à 59,3 % par mois sur les AI Overviews et à 74 % par semaine sur ChatGPT Search par l'institut Sistrix, le citation drift s'explique par la sensibilité contextuelle des LLM et la fraîcheur de l'index des RAG. Il implique qu'une position acquise dans l'IA est par nature éphémère.",
  },
  {
    letter: 'C',
    id: 'cluster-semantique',
    name: 'Cluster sémantique',
    definition: "Ensemble de pages ou contenus organisés autour d'un sujet central (page pilier) et de sous-thèmes associés (pages satellites), reliés par un maillage interne cohérent. Le cluster sémantique renforce l'autorité thématique d'un site aux yeux de Google et des LLMs. Ahrefs (août 2025) recommande explicitement la construction de clusters thématiques comme l'un des trois leviers principaux pour gagner des citations IA.",
  },
  {
    letter: 'C',
    id: 'contenu-autoporteur',
    name: 'Contenu autoporteur',
    definition: "Bloc de contenu (paragraphe, section) compréhensible et utile sans avoir besoin de lire le reste de l'article. En GEO, l'autoportance est une condition d'extractibilité : les LLMs isolent des chunks pour composer leur réponse. Si un paragraphe dépend du contexte des paragraphes précédents pour avoir du sens, il ne sera pas extrait. Chaque section doit pouvoir répondre à une question précise de façon autonome.",
  },
  {
    letter: 'C',
    id: 'contenu-duplique',
    name: 'Contenu dupliqué',
    definition: "Contenu identique ou très similaire présent sur plusieurs URLs, que ce soit à l'intérieur d'un même site ou entre plusieurs sites. Google pénalise ou ignore les pages en duplication car elles n'apportent pas de valeur supplémentaire à l'index. Les causes courantes sont les paramètres d'URL, les versions http/https, les pages de pagination ou les copies de contenu tiers. La balise canonical est la solution technique principale.",
  },
  {
    letter: 'C',
    id: 'contenu-pilier',
    name: 'Contenu pilier',
    definition: "Article long et exhaustif traitant un sujet central dans sa globalité, conçu pour être la référence principale d'un site sur ce thème. Le contenu pilier est associé à un cluster sémantique dont il constitue la page hub. Il cible des mots-clés à fort volume de recherche et est enrichi par des liens internes vers des pages satellites qui approfondissent des aspects spécifiques du sujet.",
  },
  {
    letter: 'C',
    id: 'core-web-vitals',
    name: 'Core Web Vitals',
    definition: "Ensemble de métriques définies par Google pour évaluer l'expérience utilisateur d'une page web : la vitesse de chargement (LCP - Largest Contentful Paint), la stabilité visuelle (CLS - Cumulative Layout Shift) et la réactivité aux interactions (INP - Interaction to Next Paint). Ces métriques sont des signaux de classement officiels intégrés à l'algorithme Google depuis 2021.",
  },
  {
    letter: 'C',
    id: 'crawl',
    name: 'Crawl',
    definition: "Processus par lequel les robots des moteurs de recherche (Googlebot, Bingbot, PerplexityBot) parcourent le web en suivant les liens pour découvrir et indexer les pages. La fréquence et la profondeur du crawl d'un site dépendent de son autorité, de la fraîcheur de son contenu et de la configuration du fichier robots.txt. Un site mal crawlé peut avoir du contenu invisible aux moteurs de recherche et aux LLMs.",
  },
  {
    letter: 'C',
    id: 'ctr',
    name: 'CTR (Click-Through Rate)',
    definition: "Taux de clic calculé en divisant le nombre de clics reçus par le nombre d'impressions dans les résultats de recherche. Ahrefs mesure une chute de 78 % du CTR organique en position 1 quand un AI Overview est présent (analyse sur 300 000 mots-clés, déc. 2025). Mais pour les marques effectivement citées dans un AIO, Seer Interactive documente une remontée du CTR de 1,3 % à 2,4 % entre décembre 2025 et février 2026.",
  },
  // D
  {
    letter: 'D',
    id: 'da',
    name: 'DA (Domain Authority)',
    definition: "Métrique propriétaire de Moz (0 à 100) estimant la capacité d'un domaine à se classer dans les SERPs, calculée principalement à partir de la qualité et du volume du profil de backlinks. En GEO, sa corrélation avec la visibilité dans les LLMs est faible (0,18 selon LLM Research Lab, 2026). Ahrefs propose un indicateur équivalent appelé Domain Rating (DR), et Semrush utilise l'Authority Score.",
  },
  {
    letter: 'D',
    id: 'dark-traffic-ia',
    name: 'Dark Traffic IA',
    definition: "Part du trafic web générée par une citation ou une recommandation au sein d'une réponse IA, mais qui n'est pas correctement identifiée comme telle dans les outils d'analyse (GA4). Un utilisateur peut lire une réponse sur ChatGPT ou Perplexity et, plutôt que de cliquer sur le lien, taper directement l'URL (trafic Direct) ou rechercher la marque sur Google (trafic Organique). Ce phénomène masque l'impact réel du GEO en sous-estimant le volume de visites réellement induit par les moteurs génératifs.",
  },
  {
    letter: 'D',
    id: 'densite-semantique',
    name: 'Densité sémantique',
    definition: "Mesure de la richesse du vocabulaire d'un contenu en termes liés au sujet traité. Une densité sémantique élevée signifie que le texte couvre un champ lexical large et cohérent autour de sa thématique principale, ce que les algorithmes de Google et les LLMs interprètent comme un signal de profondeur et d'expertise. S'oppose au keyword stuffing, qui consiste à répéter mécaniquement un même mot-clé.",
  },
  {
    letter: 'D',
    id: 'dynamic-retrieval',
    name: 'Dynamic Retrieval',
    definition: "Mécanisme d'ajustement en temps réel par lequel un système de RAG décide, en fonction de la complexité ou de la fraîcheur du prompt de l'utilisateur, s'il doit interroger l'index web en direct pour injecter des sources externes ou s'appuyer uniquement sur les connaissances figées du LLM. Le Dynamic Retrieval régit le déclenchement ou non des citations et des liens sortants dans des outils comme Gemini ou ChatGPT Search.",
  },
  // E
  {
    letter: 'E',
    id: 'eeat',
    name: 'E-E-A-T',
    definition: "Acronyme pour Experience, Expertise, Authoritativeness, Trustworthiness. Cadre d'évaluation de la qualité du contenu issu des Quality Rater Guidelines de Google. Le premier E (Experience) a été ajouté en 2022 pour valoriser le vécu de terrain en plus de l'expertise théorique. En GEO, l'E-E-A-T est transposé implicitement par les LLMs : ils favorisent les sources avec auteur identifié (nom, titre, affiliation), date de mise à jour récente et citations de sources primaires.",
  },
  // F
  {
    letter: 'F',
    id: 'featured-snippet',
    name: 'Featured Snippet',
    definition: "Encadré affiché en position 0 dans les résultats Google, au-dessus des liens organiques classiques, qui présente un extrait de réponse directe tiré d'une page web. Les Featured Snippets se déclenchent sur les requêtes informationnelles et peuvent prendre la forme d'un paragraphe, d'une liste ou d'un tableau. Précurseur des AI Overviews, le Featured Snippet a initié la logique de réponse directe sans clic qui caractérise aujourd'hui la recherche générative.",
  },
  {
    letter: 'F',
    id: 'front-loading',
    name: 'Front-loading',
    definition: "Pratique éditoriale qui consiste à placer la réponse principale, les chiffres clés et les définitions dans le premier tiers d'un contenu, typiquement les 200 premiers mots ou la première section après le H1. Levier central du GEO : 44,2 % des citations LLM viennent du premier tiers du contenu (Growth Memo, 2026). Concrètement : question en H2, réponse synthétique en première phrase, statistique sourcée dans le paragraphe d'ouverture.",
  },
  // G
  {
    letter: 'G',
    id: 'ga4',
    name: 'GA4 (Google Analytics 4)',
    definition: "Quatrième version de la plateforme d'analyse web de Google, déployée en remplacement d'Universal Analytics depuis juillet 2023. GA4 adopte un modèle de suivi basé sur les événements plutôt que les sessions et intègre des capacités de machine learning. Il permet notamment de suivre le trafic de référence en provenance des plateformes IA comme ChatGPT et Perplexity via les sources de trafic, bien que le dark traffic IA reste largement invisible.",
  },
  {
    letter: 'G',
    id: 'geo',
    name: 'GEO (Generative Engine Optimization)',
    definition: "Ensemble des pratiques visant à maximiser la visibilité d'un contenu dans les réponses générées par les LLMs : ChatGPT, Perplexity, Claude, Google AI Overviews, Gemini. Formalisé académiquement par Aggarwal et al. (Princeton, IIT Delhi, Georgia Tech, Allen AI) dans l'étude GEO: Generative Engine Optimization, présentée à ACM SIGKDD en août 2024. À ne pas confondre avec l'AEO (plus étroit, centré sur les extraits de réponse) ni avec le LLMO (plus large, inclut les usages non-search des LLMs).",
  },
  {
    letter: 'G',
    id: 'grounding',
    name: 'Grounding',
    definition: "Processus technique consistant à ancrer les réponses d'un LLM dans des faits vérifiables et des données réelles, généralement issues d'un index web ou d'une base documentaire privée via une architecture RAG. Le grounding vise à réduire les hallucinations en forçant le modèle à formuler son texte uniquement à partir de capsules d'information (chunks) extraites de sources légitimes et identifiables.",
  },
  {
    letter: 'G',
    id: 'gsc',
    name: 'GSC (Google Search Console)',
    definition: "Outil gratuit de Google permettant de suivre la performance d'un site dans les résultats de recherche organique. Il fournit des données sur les impressions, les clics, le CTR et le positionnement moyen par requête et par page. Depuis juin 2025, les clics provenant des AI Overviews sont comptabilisés dans les données GSC sous le type Web, sans séparation native des deux flux.",
  },
  // H
  {
    letter: 'H',
    id: 'hallucination',
    name: 'Hallucination',
    definition: "Phénomène par lequel un modèle de langage génère une réponse factuellement fausse, inventée ou déconnectée de la réalité, tout en conservant un ton affirmatif et syntaxiquement parfait. En GEO, les hallucinations sont combattues par les algorithmes de grounding (RAG), mais elles représentent un risque résiduel permanent qui pousse les moteurs comme Google à restreindre l'affichage de réponses génératives sur les requêtes sensibles de type YMYL.",
  },
  // I
  {
    letter: 'I',
    id: 'impressions',
    name: 'Impressions',
    definition: "Nombre de fois qu'une page a été affichée dans les résultats de recherche, indépendamment du fait qu'un utilisateur ait cliqué dessus. Les impressions sont mesurables dans Google Search Console. En GEO, il est courant d'observer une hausse des impressions simultanément à une baisse des clics : le contenu alimente des réponses IA sans générer de trafic direct. Ce découplage impressions/clics est l'un des signaux caractéristiques de la recherche générative.",
  },
  {
    letter: 'I',
    id: 'index',
    name: 'Index',
    definition: "Base de données dans laquelle les moteurs de recherche stockent les pages web découvertes par le crawl. Une page doit être indexée pour apparaître dans les résultats de recherche. L'indexation peut être contrôlée via la balise meta robots, le fichier robots.txt ou la balise canonical. Une page non indexée est invisible aux moteurs de recherche et aux LLMs qui récupèrent leurs sources depuis le web.",
  },
  {
    letter: 'I',
    id: 'intention-de-recherche',
    name: 'Intention de recherche',
    definition: "Objectif sous-jacent d'un utilisateur lorsqu'il effectue une requête. On distingue quatre types principaux : informationnel (comprendre, apprendre), navigationnel (accéder à un site précis), transactionnel (acheter, s'inscrire) et commercial (comparer avant d'acheter). L'alignement entre le contenu d'une page et l'intention de la requête ciblée est l'un des critères fondamentaux du positionnement SEO et de l'extractibilité GEO.",
  },
  // K
  {
    letter: 'K',
    id: 'keyword-stuffing',
    name: 'Keyword stuffing',
    definition: "Pratique consistant à répéter excessivement un mot-clé dans un contenu dans le but de manipuler les algorithmes de classement. Pénalisée par Google depuis les mises à jour Panda (2011), cette technique est doublement contre-productive en contexte GEO : l'étude Princeton SIGKDD 2024 démontre que le keyword stuffing pénalise la visibilité dans les réponses IA de 10 %.",
  },
  {
    letter: 'K',
    id: 'kpi',
    name: 'KPI (Key Performance Indicator)',
    definition: "Indicateur clé de performance permettant de mesurer l'atteinte d'un objectif défini. En SEO, les KPIs classiques sont le positionnement moyen, le trafic organique, le CTR et les backlinks. En GEO, de nouveaux KPIs s'ajoutent : l'Answer Share, la Part de voix IA, le Brand Search Lift et le trafic de référence issu des plateformes IA. La transition SEO vers GEO implique une évolution des tableaux de bord de reporting.",
  },
  // L
  {
    letter: 'L',
    id: 'landing-page',
    name: 'Landing page',
    definition: "Page web conçue spécifiquement pour recevoir un trafic ciblé et convertir les visiteurs vers une action définie : inscription, achat, téléchargement, prise de contact. En SEO, une landing page est optimisée pour une requête transactionnelle ou commerciale précise. En GEO, les landing pages sont moins exposées aux AI Overviews que les contenus informationnels, ce qui en fait des actifs relativement préservés par la recherche générative.",
  },
  {
    letter: 'L',
    id: 'llm',
    name: 'LLM (Large Language Model)',
    definition: "Modèle de langage entraîné sur de très grandes quantités de texte pour générer, comprendre et transformer du langage naturel. Les LLMs sont la technologie sous-jacente des assistants conversationnels comme ChatGPT (OpenAI), Claude (Anthropic), Gemini (Google) et Llama (Meta). La distinction importante pour le GEO : le LLM lui-même (poids, connaissances d'entraînement) vs le produit qui l'enrobe (interface, grounding, plugins). Optimiser pour ChatGPT, c'est optimiser pour le produit, pas seulement pour le modèle GPT-4o.",
  },
  {
    letter: 'L',
    id: 'llmo',
    name: 'LLMO (Large Language Model Optimization)',
    definition: "Discipline globale visant à optimiser la visibilité, la mention et la réputation d'une marque ou d'un produit au sein de l'ensemble de l'écosystème des grands modèles de langage. Plus large que le GEO (qui se focalise sur les moteurs de recherche IA et le trafic de destination), le LLMO englobe l'intégration de données dans les corpus d'entraînement initiaux, le développement de plugins dédiés et l'analyse des recommandations hors connexion web.",
  },
  {
    letter: 'L',
    id: 'longue-traine',
    name: 'Longue traîne',
    definition: "Ensemble des requêtes de recherche à faible volume individuel mais qui, cumulées, représentent une part significative du trafic total. Les requêtes longue traîne sont généralement plus spécifiques (4 mots ou plus) et indiquent un intent plus précis. En GEO, la longue traîne conversationnelle correspond aux questions précises que les utilisateurs posent directement aux LLMs, souvent formulées en langage naturel.",
  },
  // M
  {
    letter: 'M',
    id: 'maillage-interne',
    name: 'Maillage interne',
    definition: "Ensemble des liens hypertextes reliant les pages d'un même site entre elles. Un maillage interne cohérent facilite le crawl des robots des moteurs de recherche, distribue l'autorité entre les pages et guide les utilisateurs dans leur navigation. En stratégie de cluster sémantique, il structure les relations entre la page pilier et les pages satellites.",
  },
  {
    letter: 'M',
    id: 'mention-rate',
    name: 'Mention Rate',
    definition: "Fréquence absolue à laquelle le nom d'une marque apparaît dans le corps textuel des réponses générées par un LLM, qu'il y ait ou non un lien hypertexte cliquable associé. Contrairement à l'Answer Share qui se base sur les blocs de sources et de citations officielles, le Mention Rate comptabilise la simple présence sémantique de la marque au sein de la synthèse vocale ou écrite de l'IA.",
  },
  {
    letter: 'M',
    id: 'meta-description',
    name: 'Meta description',
    definition: "Balise HTML contenant un résumé de 120 à 165 caractères décrivant le contenu d'une page. Non prise en compte directement comme signal de classement par Google, elle influence le CTR en apparaissant sous le titre dans les résultats de recherche. Google peut la remplacer par un extrait de la page s'il juge son contenu plus pertinent pour la requête.",
  },
  {
    letter: 'M',
    id: 'mot-cle',
    name: 'Mot-clé',
    definition: "Terme ou expression saisi par un utilisateur dans un moteur de recherche. En SEO, les mots-clés se divisent en head keywords (mots-clés génériques à fort volume et forte concurrence) et longue traîne (expressions spécifiques à faible volume et faible concurrence). La sélection et le ciblage des mots-clés constituent la base de toute stratégie éditoriale SEO.",
  },
  {
    letter: 'M',
    id: 'moteur-generatif',
    name: 'Moteur génératif',
    definition: "Moteur de recherche dont l'interface intègre un LLM pour synthétiser une réponse directe à partir de plusieurs sources, en lieu et place d'une liste de liens. Bing Copilot, Google AI Overviews et SearchGPT sont des moteurs génératifs. À distinguer des agents conversationnels (ChatGPT, Claude, Perplexity) qui sont des outils de dialogue basés sur des LLMs sans interface de recherche traditionnelle.",
  },
  {
    letter: 'M',
    id: 'multi-turn',
    name: 'Multi-turn',
    definition: "Caractéristique d'une session de recherche conversationnelle où l'utilisateur affine son besoin à travers une série de questions et de réponses successives. Lors d'un parcours multi-turn, le LLM conserve le contexte des échanges précédents. Pour le GEO, cela implique une fragmentation des sources : un domaine cité lors du premier tour peut subir un citation drift et disparaître au troisième tour si l'intention s'affine.",
  },
  // N
  {
    letter: 'N',
    id: 'nlp',
    name: 'NLP (Natural Language Processing)',
    definition: "Branche de l'intelligence artificielle qui permet aux machines de comprendre, interpréter et générer du langage humain. Le NLP est la technologie sous-jacente des moteurs de recherche modernes et des LLMs. Google utilise des modèles NLP (BERT, MUM) pour comprendre le sens des requêtes au-delà des mots-clés exacts. En GEO, la qualité NLP d'un contenu (clarté, cohérence, structure logique) influence directement sa probabilité d'être extrait et cité.",
  },
  // O
  {
    letter: 'O',
    id: 'on-page-off-page',
    name: 'On-page / Off-page',
    definition: "Distinction fondamentale en SEO entre les optimisations réalisées directement sur les pages du site (on-page : title tag, contenu, balisage, maillage interne, Core Web Vitals) et les signaux provenant de l'extérieur du site (off-page : backlinks, mentions de marque, citations dans des sources tierces). En GEO, cette distinction s'étend : la présence sur Reddit, LinkedIn ou des médias spécialisés constitue un off-page GEO qui influence les citations IA.",
  },
  // P
  {
    letter: 'P',
    id: 'paa',
    name: 'PAA (People Also Ask)',
    definition: "Bloc de questions-réponses déroulantes affiché par Google dans la SERP, généré dynamiquement à partir des requêtes connexes les plus fréquentes autour d'un sujet. Chaque réponse est extraite d'une page web citée en source. Le PAA est un signal fort de l'intention de recherche associée à une requête. Apparaître dans le PAA suit la même logique que le Featured Snippet : contenu autoporteur, réponse directe en moins de 50 mots, structure claire.",
  },
  {
    letter: 'P',
    id: 'pagerank',
    name: 'PageRank',
    definition: "Algorithme fondateur de Google, développé par Larry Page et Sergey Brin en 1998, qui mesure l'autorité d'une page web en fonction du nombre et de la qualité des liens entrants. Le PageRank a posé les bases du SEO off-page et de la notion de backlink comme signal d'autorité. Google ne publie plus de score PageRank public depuis 2016, mais l'algorithme continue d'opérer en interne sous des formes évoluées.",
  },
  {
    letter: 'P',
    id: 'part-de-voix-ia',
    name: 'Part de voix IA',
    definition: "Part des citations d'un domaine rapportée à l'ensemble des citations de la concurrence sur les mêmes prompts. Si une marque est citée dans 30 % des réponses et ses trois concurrents dans 25, 25 et 20 %, sa part de voix IA est de 30 %. Métrique relative plus stable que le Mention Rate absolu, car elle filtre les variations liées aux prompts choisis ou aux mises à jour de modèle.",
  },
  {
    letter: 'P',
    id: 'perplexitybot',
    name: 'PerplexityBot',
    definition: "Robot d'indexation (crawler) spécifique utilisé par le moteur de réponses Perplexity AI pour parcourir les sites web, en extraire le contenu textuel et alimenter son système de RAG en temps réel. Le comportement de PerplexityBot peut être contrôlé ou bloqué via le fichier robots.txt. Son exclusion totale empêche l'apparition des contenus du site au sein des réponses de la plateforme.",
  },
  {
    letter: 'P',
    id: 'prompt',
    name: 'Prompt',
    definition: "Instruction ou question soumise à un LLM pour obtenir une réponse. En GEO, le prompt est l'équivalent de la requête SEO, mais il est souvent plus long, plus conversationnel, et peut inclure un contexte. La formulation du prompt influence fortement les sources citées et les informations présentées. Les outils de tracking GEO définissent des listes de prompts représentatifs des requêtes de la cible pour mesurer la visibilité d'une marque.",
  },
  // R
  {
    letter: 'R',
    id: 'rag',
    name: 'RAG (Retrieval-Augmented Generation)',
    definition: "Architecture technique permettant à un LLM de récupérer des informations depuis des sources externes (web, base documentaire) avant de générer sa réponse. Plutôt que de s'appuyer uniquement sur ses données d'entraînement, le modèle décompose la requête, récupère les passages les plus pertinents (chunks), puis les intègre dans sa réponse avec citations. Perplexity est architecturalement un RAG sur index web. Le RAG est le mécanisme principal par lequel les LLMs citent du contenu en temps réel.",
  },
  {
    letter: 'R',
    id: 'recherche-zero-clic',
    name: 'Recherche zéro clic',
    definition: "Requête pour laquelle l'utilisateur obtient une réponse satisfaisante directement dans la SERP ou la réponse IA, sans cliquer vers aucun site. En 2025, 60 % des recherches Google se terminaient sans clic selon SparkToro, une hausse directement liée à la généralisation des AI Overviews. En GEO, l'objectif n'est plus seulement d'être cliqué mais d'être cité, même dans une réponse qui ne génère pas de trafic direct.",
  },
  {
    letter: 'R',
    id: 'redirection',
    name: 'Redirection (301 / 302)',
    definition: "Instruction technique redirigeant automatiquement un navigateur ou un robot d'une URL vers une autre. La redirection 301 est permanente : elle transfère l'autorité SEO de l'ancienne URL vers la nouvelle. La redirection 302 est temporaire : elle ne transfère pas l'autorité. Les redirections 301 sont indispensables lors de la refonte d'un site ou du changement d'URLs pour préserver le capital SEO accumulé.",
  },
  {
    letter: 'R',
    id: 'requete-informationnelle',
    name: 'Requête informationnelle',
    definition: "Requête de recherche dont l'objectif est d'obtenir une information, une définition ou une explication. C'est le type de requête le plus fréquent et le plus exposé aux AI Overviews, qui peuvent y répondre directement sans renvoyer vers un site. Les contenus informationnels sont à la fois les plus cités par les LLMs et les plus impactés par la baisse de trafic organique liée à la recherche générative.",
  },
  {
    letter: 'R',
    id: 'requete-transactionnelle',
    name: 'Requête transactionnelle',
    definition: "Requête de recherche dont l'objectif est d'effectuer une action concrète : achat, inscription, téléchargement, réservation. Ces requêtes sont plus résistantes aux AI Overviews car elles impliquent une interaction qui ne peut pas être satisfaite dans la SERP. Elles restent le principal moteur de trafic commercial pour les sites e-commerce et les services en ligne.",
  },
  {
    letter: 'R',
    id: 'richesse-lexicale',
    name: 'Richesse lexicale',
    definition: "Diversité du vocabulaire utilisé dans un contenu, mesurée par le ratio entre le nombre de mots uniques et le nombre total de mots. Une richesse lexicale élevée est associée à un contenu de qualité par les algorithmes NLP. En SEO sémantique, elle contribue à la densité sémantique et à la couverture thématique d'une page.",
  },
  {
    letter: 'R',
    id: 'robots-txt',
    name: 'Robots.txt',
    definition: "Fichier texte placé à la racine d'un site qui indique aux robots des moteurs de recherche quelles pages ou répertoires ils sont autorisés ou non à crawler. Les directives Disallow empêchent le crawl de certaines URLs. Attention : robots.txt empêche le crawl mais pas nécessairement l'indexation si d'autres pages pointent vers les URLs bloquées. Bloquer PerplexityBot dans robots.txt exclut le site de l'index Perplexity.",
  },
  // S
  {
    letter: 'S',
    id: 'score-de-visibilite',
    name: 'Score de visibilité',
    definition: "Indicateur agrégé utilisé par les outils SEO (Semrush, Sistrix, Ahrefs) pour mesurer la présence globale d'un site dans les SERPs sur un ensemble de mots-clés suivis. En GEO, ce concept évolue vers la Part de voix IA et l'Answer Share, qui mesurent la visibilité dans les réponses des LLMs plutôt que dans les listes de résultats.",
  },
  {
    letter: 'S',
    id: 'serp',
    name: 'SERP (Search Engine Results Page)',
    definition: "Page de résultats affichée par un moteur de recherche en réponse à une requête. La SERP moderne inclut de multiples types de résultats : liens organiques, annonces payantes, Featured Snippets, knowledge panels, carousels d'images ou vidéos, et AI Overviews. La concurrence pour la visibilité dans la SERP constitue l'objet central du SEO.",
  },
  {
    letter: 'S',
    id: 'seo',
    name: 'SEO (Search Engine Optimization)',
    definition: "Ensemble des pratiques visant à améliorer le positionnement d'un site ou d'une page dans les résultats organiques des moteurs de recherche. Le SEO se divise en trois grandes dimensions : le SEO technique (crawlabilité, vitesse, structure), le SEO on-page (contenu, mots-clés, balisage) et le SEO off-page (backlinks, autorité). Il reste la fondation sur laquelle le GEO s'appuie : 54,5 % des sources citées dans les AI Overviews proviennent de pages classées organiquement (BrightEdge, sept. 2025).",
  },
  {
    letter: 'S',
    id: 'shadow-ban',
    name: 'Shadow ban',
    definition: "Sanction silencieuse appliquée par une plateforme (Reddit, X, Instagram...) qui rend le contenu d'un compte invisible pour les autres utilisateurs sans en informer le propriétaire. Sur Reddit, le shadow ban filtre les comptes suspects ou spammeurs. Un compte shadowbané peut publier normalement depuis son interface, mais ses posts et commentaires n'apparaissent pas pour les autres membres ni dans les résultats de recherche.",
  },
  {
    letter: 'S',
    id: 'sitemap',
    name: 'Sitemap',
    definition: "Fichier XML listant l'ensemble des URLs d'un site que l'on souhaite faire indexer par les moteurs de recherche. Le sitemap facilite et accélère le crawl, notamment pour les sites récents ou de grande taille. Il est soumis directement à Google via la Search Console. Un sitemap bien maintenu améliore la couverture d'indexation et donc la visibilité potentielle dans les SERPs et les réponses IA.",
  },
  {
    letter: 'S',
    id: 'slug',
    name: 'Slug',
    definition: "Partie d'une URL identifiant une page spécifique, généralement dérivée du titre de la page, en minuscules, sans accents, avec des tirets à la place des espaces. Le slug contribue à la lisibilité et à la pertinence SEO de l'URL. Un bon slug est court, descriptif et contient le mot-clé principal de la page.",
  },
  {
    letter: 'S',
    id: 'sxo',
    name: 'SXO (Search Experience Optimization)',
    definition: "Approche combinant SEO et UX (expérience utilisateur) pour optimiser à la fois le positionnement dans les moteurs de recherche et la satisfaction de l'utilisateur une fois sur la page. Le SXO part du principe qu'un bon classement sans une expérience utilisateur satisfaisante ne génère pas de résultats business. Il intègre des métriques comme le taux de rebond, le temps passé et le taux de conversion aux indicateurs SEO classiques.",
  },
  // T
  {
    letter: 'T',
    id: 'taux-de-rebond',
    name: 'Taux de rebond',
    definition: "Pourcentage de sessions au cours desquelles un utilisateur quitte un site après n'avoir consulté qu'une seule page, sans interaction. Un taux de rebond élevé peut signaler un désalignement entre le contenu de la page et l'intention de recherche. En GA4, le taux de rebond est remplacé par le taux d'engagement, qui mesure les sessions avec au moins une interaction significative.",
  },
  {
    letter: 'T',
    id: 'title-tag',
    name: 'Title tag',
    definition: "Balise HTML définissant le titre d'une page web, affiché dans l'onglet du navigateur et comme titre cliquable dans les résultats de recherche. Le title tag est l'un des signaux on-page les plus importants pour le SEO. Sa longueur optimale est de 50 à 70 caractères. Google peut le réécrire s'il le juge mal aligné avec la requête ou le contenu de la page.",
  },
  {
    letter: 'T',
    id: 'token',
    name: 'Token',
    definition: "Unité de base du traitement du texte par un LLM. Un token correspond approximativement à un mot, une ponctuation ou une syllabe selon le modèle. Les LLMs ont une fenêtre de contexte maximale exprimée en tokens (ex. : 128 000 tokens pour GPT-4o), qui détermine la quantité de texte qu'ils peuvent traiter en une seule fois. La facturation des API de LLMs est généralement basée sur le nombre de tokens consommés.",
  },
  // U
  {
    letter: 'U',
    id: 'ugc',
    name: 'UGC (User-Generated Content)',
    definition: "Contenu produit par les utilisateurs d'une plateforme plutôt que par ses éditeurs : avis, commentaires, posts de forum, threads Reddit, photos... Le UGC bénéficie d'une forte crédibilité auprès des LLMs car il reflète des expériences authentiques et non promotionnelles. Reddit concentrait 40,1 % des citations LLM en 2025 selon Semrush, ce qui en fait la principale source de UGC cité par les IA.",
  },
  {
    letter: 'U',
    id: 'url',
    name: 'URL (Uniform Resource Locator)',
    definition: "Adresse unique identifiant une ressource sur le web, composée d'un protocole (https://), d'un nom de domaine et d'un chemin. En SEO, une URL bien construite est courte, lisible, sans paramètres superflus, et contient le mot-clé principal de la page via son slug. Les URLs sont des signaux on-page pris en compte par Google et facilitent la compréhension du contenu par les LLMs lors du crawl.",
  },
  // Y
  {
    letter: 'Y',
    id: 'ymyl',
    name: 'YMYL (Your Money or Your Life)',
    definition: "Catégorie de sujets définie par Google dans ses Quality Rater Guidelines qui désigne les contenus pouvant avoir un impact significatif sur la santé, la sécurité financière ou le bien-être des utilisateurs (santé, finance, droit, actualité...). Les pages YMYL sont soumises à des exigences E-E-A-T plus strictes. En GEO, la catégorie YMYL détermine souvent le comportement des IA : forte couverture AIO sur le contenu éducatif santé et finance, mais exclusions totales sur les sujets à risque.",
  },
];

const grouped = terms.reduce((acc, term) => {
  if (!acc[term.letter]) acc[term.letter] = [];
  acc[term.letter].push(term);
  return acc;
}, {} as Record<string, typeof terms>);

const letters = Object.keys(grouped).sort();
---

<BaseLayout
  title="Lexique SEO & GEO — Jean-Baptiste Récolet"
  description="Définitions claires des termes et acronymes du SEO, du GEO et de la recherche générative : LLM, RAG, E-E-A-T, CTR, SERP, AI Overviews et bien d'autres."
>
  <div class="lexique">

    <header class="lexique__header">
      <h1>Lexique SEO & GEO</h1>
      <p class="lexique__intro">
        Définitions des termes, sigles et acronymes essentiels du référencement naturel et de la recherche générative. Chaque entrée est rédigée pour être citée par les moteurs IA.
      </p>
      <nav class="lexique__nav" aria-label="Navigation alphabétique">
        {letters.map((letter) => (
          <a href={`#lettre-${letter}`}>{letter}</a>
        ))}
      </nav>
    </header>

    {letters.map((letter) => (
      <section class="lexique__section" id={`lettre-${letter}`}>
        <h2 class="lexique__letter">{letter}</h2>
        <dl class="lexique__list">
          {grouped[letter].map((term) => (
            <>
              <dt class="lexique__term" id={term.id}>
                <a href={`#${term.id}`} class="lexique__anchor">{term.name}</a>
              </dt>
              <dd class="lexique__def">{term.definition}</dd>
            </>
          ))}
        </dl>
      </section>
    ))}

  </div>
</BaseLayout>

<style>
  .lexique {
    max-width: var(--max-w-text);
    margin: 0 auto;
  }

  .lexique__header {
    margin-bottom: var(--space-xl);
  }

  .lexique__intro {
    margin-top: var(--space-sm);
    color: var(--color-muted);
    font-size: 1.1rem;
  }

  .lexique__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: var(--space-lg);
    padding: var(--space-md);
    background: var(--color-rule);
    border-radius: var(--radius);
    max-width: none;
  }

  .lexique__nav a {
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    color: var(--color-accent);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius);
    transition: background 0.15s;
  }

  .lexique__nav a:hover {
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
  }

  .lexique__section {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 2px solid var(--color-rule);
  }

  .lexique__letter {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    color: var(--color-accent);
    margin-top: 0;
    margin-bottom: var(--space-md);
  }

  .lexique__list {
    max-width: none;
  }

  .lexique__term {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.125rem;
    margin-top: var(--space-lg);
    color: var(--color-text);
    scroll-margin-top: 80px;
  }

  .lexique__term:first-child {
    margin-top: 0;
  }

  .lexique__anchor {
    color: inherit;
    text-decoration: none;
  }

  .lexique__anchor:hover {
    color: var(--color-accent);
  }

  .lexique__def {
    margin-top: var(--space-xs);
    margin-left: 0;
    color: var(--color-text);
    line-height: 1.7;
    max-width: none;
  }
</style>
