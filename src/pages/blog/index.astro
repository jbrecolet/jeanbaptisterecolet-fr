---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog - SEO, GEO et Content Management"
  description="Articles, guides et veille sur l'évolution du Search en 2026."
>
  <section class="section">
    <h1>Blog</h1>
    <p class="section__intro">
      Analyses et méthodes sur le SEO classique, le GEO et la stratégie de contenu.
    </p>
    {sortedPosts.length === 0 ? (
      <p>Aucun article pour le moment.</p>
    ) : (
      <ul class="article-grid">
        {sortedPosts.map((post) => (
          <li class="article-card">
            {post.data.cover && (
              <a href={`/blog/${post.id}`} class="article-card__thumb" tabindex="-1" aria-hidden="true">
                <img
                  src={`/${post.data.cover}`}
                  alt={post.data.coverAlt ?? ''}
                />
              </a>
            )}
            <div class="article-card__body">
              <p class="article-card__category">{post.data.category?.toUpperCase()}</p>
              <h3 class="article-card__title">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h3>
              <p class="article-card__desc">{post.data.description}</p>
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .section { margin-top: var(--space-xl); }
  .section__intro {
    margin-bottom: var(--space-lg);
    color: var(--color-muted);
    font-size: 1.2rem;
    max-width: none;
  }

  .article-grid {
    list-style: none;
    padding: 0;
    max-width: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .article-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    border-top: 1px solid var(--color-rule);
    padding-top: var(--space-md);
  }

  .article-card__thumb {
    display: block;
    width: 100%;
  }
  .article-card__thumb img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    border-radius: var(--radius);
  }
  .article-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }
  .article-card__category { font-size: 0.8rem; color: var(--color-accent); font-weight: bold; }
  .article-card__title { margin: 0; }
  .article-card__title a { text-decoration: none; color: inherit; }
  .article-card__title a:hover { color: var(--color-accent); }
  .article-card__desc { color: var(--color-muted); font-size: 0.9375rem; }

  @media (max-width: 900px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .article-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
