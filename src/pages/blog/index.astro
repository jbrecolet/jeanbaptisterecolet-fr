---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const getExcerpt = (entry) => {
  if (entry.data.excerpt) return entry.data.excerpt;
  const paragraphs = (entry.body ?? '').split('\n\n').filter(p => {
    const t = p.trim();
    return (
      t &&
      !t.startsWith('#') &&
      !t.startsWith('---') &&
      !t.startsWith('<') &&
      !t.startsWith('|') &&
      !t.startsWith('-') &&
      !t.startsWith('*')
    );
  });
  const first = paragraphs[0]
    ?.replace(/\*\*/g, '')
    .replace(/\*/g, '')
    .replace(/_/g, '')
    .trim();
  return first || entry.data.description;
};
---

<BaseLayout
  title="Blog - SEO, GEO et Content Management"
  description="Articles, guides et veille sur l'évolution du Search en 2026."
>
  <section class="section">
    <h1>
      <span class="page-header__title">Blog</span>
      <span class="page-header__subtitle"><em>Analyses et guides sur le SEO, le GEO et la stratégie de contenu</em></span>
    </h1>

    {sortedPosts.length === 0 ? (
      <p>Aucun article pour le moment.</p>
    ) : (
      <ul class="article-grid">
        {sortedPosts.map((post) => (
          <li class="article-card">
            {post.data.cover && (
              <a href={`/blog/${post.id}`} class="article-card__thumb" tabindex="-1" aria-hidden="true">
                <img
                  src={`/${post.data.cover}`}
                  alt={post.data.coverAlt ?? ''}
                />
              </a>
            )}
            <div class="article-card__body">
              <p class="article-card__category">{post.data.category?.toUpperCase()}</p>
              <h3 class="article-card__title">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h3>
              <p class="article-card__desc">{getExcerpt(post)}</p>
            </div>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .section { margin-top: var(--space-xl); }

  .article-grid {
    list-style: none;
    padding: 0;
    max-width: none;
    margin-top: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: calc(var(--space-lg) / 8);
  }

  .article-card {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-lg);
    padding: calc(var(--space-md) / 2) 0;
  }

  .article-card:first-child {
    padding-top: 0;
  }

  .article-card__thumb {
    display: block;
    width: 100%;
  }
  .article-card__thumb img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
    border-radius: var(--radius);
  }

  .article-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    justify-content: center;
  }

  .article-card__category { font-size: 0.8rem; color: var(--color-accent); font-weight: bold; }
  .article-card__title { margin: 0; font-size: 1.35rem; }
  .article-card__title a { text-decoration: none; color: inherit; }
  .article-card__title a:hover { color: var(--color-accent); }

  .article-card__desc {
    color: var(--color-muted);
    font-size: 0.9375rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 700px) {
    .article-card {
      grid-template-columns: 1fr;
    }
    .article-card__thumb img {
      height: 200px;
    }
  }
</style>
