---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { data, id } = entry;
const url = new URL(`/blog/${id}`, Astro.site).href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.description,
  datePublished: data.pubDate.toISOString(),
  dateModified: (data.updatedDate ?? data.pubDate).toISOString(),
  inLanguage: 'fr-FR',
  author: {
    '@type': 'Person',
    name: 'Jean-Baptiste Récolet',
    url: 'https://jeanbaptisterecolet.fr',
    sameAs: ['https://www.linkedin.com/in/jbrecolet/'],
  },
  publisher: {
    '@type': 'Person',
    name: 'Jean-Baptiste Récolet',
    url: 'https://jeanbaptisterecolet.fr',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': url,
  },
  keywords: data.keywords ?? data.tags,
  articleSection: data.category,
};

const faqSchema = data.faq && data.faq.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: data.faq.map((q) => ({
        '@type': 'Question',
        name: q.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: q.answer,
        },
      })),
    }
  : null;

const dateFmt = new Intl.DateTimeFormat('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title={data.title}
  description={data.description}
  type="article"
  publishedTime={data.pubDate}
  modifiedTime={data.updatedDate}
  tags={data.tags}
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {faqSchema && (
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}

  <article class="article">

    {data.cover && (
      <figure class="cover-figure">
        <img
          src={`/${data.cover}`}
          alt={data.coverAlt ?? data.title}
          class="cover-img"
        />
      </figure>
    )}

    <header class="article__header">
      <p class="article__category">{data.category?.toUpperCase()}</p>
      <h1 class="article__title">{data.title}</h1>
<p class="article__meta">
  <time datetime={data.pubDate.toISOString()}>
    Publié le {dateFmt.format(data.pubDate)}
  </time>
  {' · Par '}<a href="/a-propos">Jean-Baptiste Récolet</a>
</p>
{data.updatedDate && (
  <p class="article__meta article__meta--updated">
    <time datetime={data.updatedDate.toISOString()}>
      Mis à jour le {dateFmt.format(data.updatedDate)}
    </time>
  </p>
)}
    </header>

    <div class="article__body">
      <slot />
    </div>

    {data.faq && data.faq.length > 0 && (
      <>
        <hr class="faq-divider" />
        <section class="faq-block">
          <h2>Questions fréquentes</h2>
          <dl>
            {data.faq.map((item) => (
              <>
                <dt>{item.question}</dt>
                <dd>{item.answer}</dd>
              </>
            ))}
          </dl>
        </section>
      </>
    )}

  </article>
</BaseLayout>

<style>
  .cover-figure {
    margin: 0 0 var(--space-lg);
  }
  .cover-img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    border-radius: var(--radius);
    display: block;
  }

  .article__header {
    margin-bottom: var(--space-lg);
  }

  .faq-divider {
    border: none;
    border-top: 2px solid var(--color-rule);
    margin: var(--space-lg) 0 0;
    max-width: var(--max-w-text);
  }

  .faq-block {
    max-width: var(--max-w-text);
    padding-top: var(--space-md);
  }

  .faq-block h2 {
    margin-top: 0;
    margin-bottom: var(--space-md);
  }

  .faq-block dt {
    font-weight: 600;
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    margin-top: var(--space-md);
    color: var(--color-text);
  }

  .faq-block dd {
    margin-top: var(--space-xs);
    margin-left: 0;
    color: var(--color-text);
    line-height: 1.65;
    max-width: none;
  }
</style>
