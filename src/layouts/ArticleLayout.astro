---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { data, id } = entry;
const url = new URL(`/blog/${id}`, Astro.site).href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.description,
  datePublished: data.pubDate.toISOString(),
  dateModified: (data.updatedDate ?? data.pubDate).toISOString(),
  inLanguage: 'fr-FR',
  author: {
    '@type': 'Person',
    name: 'Jean-Baptiste Récolet',
    url: 'https://jeanbaptisterecolet.fr',
    sameAs: ['https://www.linkedin.com/in/jbrecolet/'],
  },
  publisher: {
    '@type': 'Person',
    name: 'Jean-Baptiste Récolet',
    url: 'https://jeanbaptisterecolet.fr',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': url,
  },
  keywords: data.keywords ?? data.tags,
  articleSection: data.category,
};

const faqSchema = data.faq && data.faq.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: data.faq.map((q) => ({
        '@type': 'Question',
        name: q.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: q.answer,
        },
      })),
    }
  : null;

const dateFmt = new Intl.DateTimeFormat('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title={data.title}
  description={data.description}
  type="article"
  publishedTime={data.pubDate}
  modifiedTime={data.updatedDate}
  tags={data.tags}
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {faqSchema && (
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}

  <article class="article">

    {data.cover && (
      <figure class="article__cover">
        <img
          src={`/${data.cover}`}
          alt={data.coverAlt ?? data.title}
          class="article__cover-img"
        />
      </figure>
    )}

    <header class="article__header">
      <p class="article__category">{data.category?.toUpperCase()}</p>
      <h1 class="article__title">{data.title}</h1>
      <p class="article__meta">
        <time datetime={data.pubDate.toISOString()}>
          Publié le {dateFmt.format(data.pubDate)}
        </time>
        {data.updatedDate && (
          <>
            {' · '}
            <time datetime={data.updatedDate.toISOString()}>
              Mis à jour le {dateFmt.format(data.updatedDate)}
            </time>
          </>
        )}
        {' · Par '}<a href="/a-propos">Jean-Baptiste Récolet</a>
      </p>
    </header>

    <div class="article__body">
      <slot />
    </div>

    {data.tldr && (
      <aside class="article__tldr" aria-label="En résumé">
        <strong>En résumé.</strong> {data.tldr}
      </aside>
    )}

    {data.faq && data.faq.length > 0 && (
      <section class="article__faq">
        <h2>Questions fréquentes</h2>
        <dl>
          {data.faq.map((item) => (
            <>
              <dt>{item.question}</dt>
              <dd>{item.answer}</dd>
            </>
          ))}
        </dl>
      </section>
    )}

  </article>
</BaseLayout>

<style>
  .article__cover {
    margin: 0 0 var(--space-lg);
  }
  .article__cover-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    display: block;
  }

  .article__header {
    margin-bottom: var(--space-lg);
  }

  .article__tldr {
    background: var(--color-card);
    border-left: 3px solid var(--color-accent);
    padding: var(--space-md);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-lg);
    border-radius: 0 var(--radius) var(--radius) 0;
    max-width: var(--max-w-text);
  }

  .article__faq {
    margin-top: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 2px solid var(--color-rule) !important;
    max-width: var(--max-w-text);
  }
</style>
