---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { data, id } = entry;

const url = new URL(`/blog/${id}`, Astro.site).href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.description,
  datePublished: data.pubDate.toISOString(),
  dateModified: (data.updatedDate ?? data.pubDate).toISOString(),
  inLanguage: 'fr-FR',
  author: {
    '@type': 'Person',
    name: 'Jean-Baptiste Recolet',
    url: 'https://jeanbaptisterecolet.fr',
    sameAs: ['https://www.linkedin.com/in/jbrecolet/'],
  },
  publisher: {
    '@type': 'Person',
    name: 'Jean-Baptiste Recolet',
    url: 'https://jeanbaptisterecolet.fr',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': url,
  },
  keywords: data.keywords ?? data.tags,
  articleSection: data.category,
};

const faqSchema = data.faq && data.faq.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: data.faq.map((q) => ({
        '@type': 'Question',
        name: q.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: q.answer,
        },
      })),
    }
  : null;

const dateFmt = new Intl.DateTimeFormat('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title={data.title}
  description={data.description}
  type="article"
  publishedTime={data.pubDate}
  modifiedTime={data.updatedDate}
  tags={data.tags}
>
  <script
    is:inline
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(articleSchema)}
  />
  {faqSchema && (
    <script
      is:inline
      slot="head"
      type="application/ld+json"
      set:html={JSON.stringify(faqSchema)}
    />
  )}

  <article class="article">
    <header class="article__header">
      <p class="article__category">
        <a href={`/tag/${data.category}`}>{data.category.toUpperCase()}</a>
      </p>
      <h1 class="article__title">{data.title}</h1>
      <p class="article__meta">
        <time datetime={data.pubDate.toISOString()}>
          Publie le {dateFmt.format(data.pubDate)}
        </time>
        {data.updatedDate && (
          <>
            {' - '}
            <time datetime={data.updatedDate.toISOString()}>
              Mis a jour le {dateFmt.format(data.updatedDate)}
            </time>
          </>
        )}
        {' - Par '}<a href="/a-propos">Jean-Baptiste Recolet</a>
      </p>

      {data.tldr && (
        <aside class="article__tldr" aria-label="TLDR">
          <strong>TLDR.</strong> {data.tldr}
        </aside>
      )}
    </header>
      {data.cover && (
  <figure class="article__cover">
    <img src={data.cover} alt={data.coverAlt ?? data.title} class="article__cover-img" />
  </figure>
      )}
    <div class="article__body">
      <slot />
    </div>

    {data.faq && data.faq.length > 0 && (
      <section class="article__faq" aria-labelledby="faq-title">
        <h2 id="faq-title">Questions frequentes</h2>
        <dl>
          {data.faq.map((item) => (
            <>
              <dt>{item.question}</dt>
              <dd>{item.answer}</dd>
            </>
          ))}
        </dl>
      </section>
    )}

    <footer class="article__footer">
      <ul class="article__tags">
        {data.tags.map((tag) => (
          <li><a href={`/tag/${tag}`}>#{tag}</a></li>
        ))}
      </ul>
    </footer>
  </article>
</BaseLayout>
