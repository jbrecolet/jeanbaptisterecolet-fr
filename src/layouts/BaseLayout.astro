---
import SEO from '~/components/SEO.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import '~/styles/global.css';
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
}
const props = Astro.props;
// Schema.org Person + WebSite (présent sur toutes les pages)
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jean-Baptiste Récolet',
  jobTitle: 'Content Manager spécialisé Brand, SEO et GEO',
  url: 'https://www.jeanbaptisterecolet.fr',
  email: 'mailto:contact@jeanbaptisterecolet.fr',
  sameAs: ['https://www.linkedin.com/in/jbrecolet/'],
  knowsAbout: [
    'SEO',
    'GEO',
    'Generative Engine Optimization',
    'Content Marketing',
    'Rédaction web',
    "Optimisation pour les moteurs d'IA",
    'Workflows IA',
  ],
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'Île-de-France',
    addressCountry: 'FR',
  },
};
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Jean-Baptiste Récolet',
  alternateName: 'GEO et SEO en français',
  url: 'https://www.jeanbaptisterecolet.fr',
  inLanguage: 'fr-FR',
  description:
    'Site éditorial francophone sur le GEO, la transition SEO → GEO et les méthodes pour Content Managers.',
  author: { '@type': 'Person', name: 'Jean-Baptiste Récolet' },
  publisher: { '@type': 'Person', name: 'Jean-Baptiste Récolet' },
};
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <SEO {...props} />
    <!-- Schema.org JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(personSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />
    <!-- Consentement par défaut (mode cookieless) -->
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        analytics_storage: 'granted',
        ad_storage: 'denied',
        wait_for_update: 500
      });
    </script>
    <!-- Google Tag Manager -->
    <script>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-N8J479VX');
    </script>
    <!-- End Google Tag Manager -->
    <!-- Préchargement de la police principale -->
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,600&display=swap"
    />
    <!-- RSS auto-découverte -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Jean-Baptiste Récolet — Articles"
      href="/rss.xml"
    />
    <slot name="head" />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-N8J479VX"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a href="#main" class="skip-link">Aller au contenu principal</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
