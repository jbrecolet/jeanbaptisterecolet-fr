---
import SEO from '~/components/SEO.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import '~/styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
}

const props = Astro.props;

// Schema.org Person + WebSite (présent sur toutes les pages)
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jean-Baptiste Recolet',
  jobTitle: 'Content Manager spécialisé SEO et GEO',
  url: 'https://jeanbaptisterecolet.fr',
  email: 'mailto:contact@jeanbaptisterecolet.fr',
  sameAs: ['https://www.linkedin.com/in/jbrecolet/'],
  knowsAbout: [
    'SEO',
    'GEO',
    'Generative Engine Optimization',
    'Content Marketing',
    'Rédaction web',
    "Optimisation pour les moteurs d'IA",
    'Workflows IA',
  ],
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'Île-de-France',
    addressCountry: 'FR',
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Jean-Baptiste Recolet',
  alternateName: 'GEO et SEO en français',
  url: 'https://jeanbaptisterecolet.fr',
  inLanguage: 'fr-FR',
  description:
    'Site éditorial francophone sur le GEO, la transition SEO → GEO et les méthodes pour Content Managers.',
  author: { '@type': 'Person', name: 'Jean-Baptiste Recolet' },
  publisher: { '@type': 'Person', name: 'Jean-Baptiste Recolet' },
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <SEO {...props} />

    <!-- Schema.org JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(personSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteSchema)}
    />

    <!-- Préchargement de la police principale -->
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap"
    />

    <!-- RSS auto-découverte -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Jean-Baptiste Recolet — Articles"
      href="/rss.xml"
    />

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Aller au contenu principal</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
